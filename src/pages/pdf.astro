---
import { cv } from '../data/cv.ts';
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Daniele Porcaro – CV</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: #fff;
      color: #111;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 11.5px;
      line-height: 1.75;
    }

    /* ── print bar (hidden when printing) ── */
    .print-bar {
      position: fixed; top: 0; left: 0; right: 0;
      background: #0a0a0f; color: #00ff88;
      padding: 12px 24px;
      display: flex; align-items: center; justify-content: space-between;
      font-size: 12px; z-index: 100;
      border-bottom: 1px solid #1e1e2e;
    }
    .print-bar button {
      background: #00ff88; color: #000; border: none;
      padding: 7px 20px; font-family: inherit;
      font-size: 12px; font-weight: 700; cursor: pointer; border-radius: 5px;
    }
    .print-bar button:hover { background: #00cc6a; }
    body { padding-top: 52px; }
    @media print {
      .print-bar { display: none !important; }
      body { padding-top: 0; }
    }

    /* ── page ── */
    .page {
      max-width: 210mm;
      margin: 0 auto;
      padding: 18mm 20mm 16mm;
    }

    /* ── header ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding-bottom: 14px;
      margin-bottom: 18px;
      border-bottom: 2px solid #111;
    }
    .header-name {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1;
    }
    .header-role {
      font-size: 12px;
      color: #555;
      font-weight: 400;
      margin-top: 5px;
    }
    .header-right {
      text-align: right;
      font-size: 10.5px;
      color: #444;
      line-height: 2;
    }
    .header-right a { color: #111; text-decoration: none; }

    /* ── section titles ── */
    .section { margin-top: 18px; }
    .section-title {
      font-size: 8.5px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #888;
      border-bottom: 1px solid #e0e0e0;
      padding-bottom: 5px;
      margin-bottom: 12px;
    }

    /* ── two-column grid ── */
    .two-col {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 24px;
      margin-top: 18px;
    }

    /* ── items ── */
    .item { margin-bottom: 13px; }
    .item:last-child { margin-bottom: 0; }

    .item-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
    }
    .item-name { font-weight: 700; font-size: 11.5px; }
    .item-date { font-size: 10px; color: #666; white-space: nowrap; }
    .item-sub { font-size: 10px; color: #555; margin-top: 1px; }
    .item-desc { font-size: 10px; color: #444; margin-top: 4px; line-height: 1.65; }

    /* ── highlights ── */
    .highlights { list-style: none; margin-top: 4px; }
    .highlights li { font-size: 10px; color: #666; padding-left: 10px; position: relative; }
    .highlights li::before { content: '·'; position: absolute; left: 0; color: #aaa; }

    /* ── skill bars ── */
    .skill-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    .skill-name { width: 88px; font-size: 10px; color: #333; }
    .skill-bar { flex: 1; height: 3px; background: #ebebeb; border-radius: 2px; overflow: hidden; }
    .skill-fill { height: 100%; background: #333; border-radius: 2px; }
    .skill-pct { font-size: 9px; color: #aaa; width: 26px; text-align: right; }

    /* ── tags ── */
    .tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }
    .tag {
      font-size: 9px; padding: 2px 7px;
      border: 1px solid #ddd; border-radius: 4px; color: #444;
    }

    /* ── competition box ── */
    .competition {
      background: #f7f7f7;
      padding: 8px 12px;
      border-left: 3px solid #111;
      margin-bottom: 10px;
      border-radius: 0 4px 4px 0;
    }

    /* ── language pills ── */
    .lang-grid { display: flex; gap: 16px; flex-wrap: wrap; }
    .lang-item { }
    .lang-code { font-weight: 700; font-size: 12px; }
    .lang-label { font-size: 10px; color: #333; }
    .lang-sub { font-size: 9.5px; color: #888; }

    /* ── btc box ── */
    .btc-box {
      background: #f9f9f9; border: 1px solid #e0e0e0;
      padding: 6px 10px; border-radius: 4px; margin-top: 5px;
    }
    .btc-box code { font-size: 8.5px; word-break: break-all; color: #555; }

    /* ── divider ── */
    .divider { border: none; border-top: 1px solid #ebebeb; margin: 14px 0; }

    @page { size: A4; margin: 0; }
    @media print {
      .page { padding: 15mm 18mm 14mm; }
      .item { margin-bottom: 11px; }
      .section { margin-top: 14px; }
    }
  </style>
</head>
<body>
  <div class="print-bar">
    <span style="opacity:0.7">~/daniele.porcaro</span>
    <button onclick="window.print()">↓ Salva come PDF &nbsp;(Ctrl+P)</button>
  </div>

  <div class="page">

    <!-- HEADER -->
    <div class="header">
      <div>
        <div class="header-name">Daniele Porcaro</div>
        <div class="header-role">Studente di Informatica &nbsp;·&nbsp; Torino, IT</div>
      </div>
      <div class="header-right">
        <div><a href={`mailto:${cv.email}`}>{cv.email}</a></div>
        <div><a href={cv.githubUrl}>github.com/{cv.github}</a></div>
        <div>18 anni &nbsp;·&nbsp; <a href="https://dany80213.github.io/cv">dany80213.github.io/cv</a></div>
      </div>
    </div>

    <!-- PROFILO -->
    <div class="section" style="margin-top:0;">
      <div class="section-title">Profilo</div>
      <p style="font-size:10.5px; color:#333; line-height:1.75; max-width:680px;">{cv.about.it}</p>
    </div>

    <!-- TWO COLUMN -->
    <div class="two-col">

      <!-- ── LEFT: sidebar ── -->
      <div>

        <!-- FORMAZIONE -->
        <div class="section" style="margin-top:0;">
          <div class="section-title">Formazione</div>
          {cv.education.map(e => (
            <div class="item">
              <div class="item-name">{e.school}</div>
              <div class="item-sub">{e.degree.it}</div>
              <div class="item-sub" style="color:#999;">{e.location}</div>
              <div class="item-date" style="margin-top:2px;">{e.period}</div>
              {e.highlights.it.length > 0 && (
                <ul class="highlights">
                  {e.highlights.it.map(h => <li>{h}</li>)}
                </ul>
              )}
            </div>
          ))}
        </div>

        <!-- LINGUE -->
        <div class="section">
          <div class="section-title">Lingue</div>
          <div style="display:flex; flex-direction:column; gap:8px;">
            {cv.languages.map(l => (
              <div>
                <span class="lang-code">{l.code}</span>
                <span class="lang-label"> &nbsp;{l.lang}</span>
                <div class="lang-sub">{typeof l.level === 'object' ? l.level.it : l.level}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- SOFT SKILLS -->
        <div class="section">
          <div class="section-title">Soft Skills</div>
          <div class="tags">
            {cv.softSkills.it.map(s => <span class="tag">{s}</span>)}
          </div>
        </div>

        <!-- LINGUAGGI -->
        <div class="section">
          <div class="section-title">Linguaggi</div>
          {cv.skills.languages.map(s => (
            <div class="skill-row">
              <span class="skill-name">{s.name}</span>
              <div class="skill-bar"><div class="skill-fill" style={`width:${s.level}%`}></div></div>
              <span class="skill-pct">{s.level}%</span>
            </div>
          ))}
        </div>

        <!-- TOOLS -->
        <div class="section">
          <div class="section-title">Framework & Tools</div>
          <div class="tags">{cv.skills.frameworks.map(f => <span class="tag">{f}</span>)}</div>
          <div class="tags">{cv.skills.devops.map(d => <span class="tag">{d}</span>)}</div>
          <div class="tags">{cv.skills.databases.map(d => <span class="tag">{d}</span>)}</div>
        </div>

        <!-- HARDWARE -->
        <div class="section">
          <div class="section-title">Hardware & Net</div>
          <div class="tags">{cv.skills.hardware.map(h => <span class="tag">{h}</span>)}</div>
          <div class="tags">{cv.skills.networking.map(n => <span class="tag">{n}</span>)}</div>
        </div>

        <!-- BLOCKCHAIN & AI -->
        <div class="section">
          <div class="section-title">Blockchain & AI</div>
          <div class="tags">{cv.skills.blockchain.map(b => <span class="tag">{b}</span>)}</div>
          <div class="tags">{cv.skills.ai.map(a => <span class="tag">{a}</span>)}</div>
        </div>

      </div>

      <!-- ── RIGHT: main content ── -->
      <div>

        <!-- PROGETTI -->
        <div class="section" style="margin-top:0;">
          <div class="section-title">Progetti</div>
          {cv.projects.map(p => (
            <div class="item">
              <div class="item-header">
                <span class="item-name">{typeof p.name === 'string' ? p.name : p.name.it}</span>
                {p.url && (
                  <a href={p.url} style="font-size:9px; color:#888; text-decoration:none;">↗ GitHub</a>
                )}
              </div>
              <div class="item-desc">{typeof p.description === 'object' ? p.description.it : p.description}</div>
              <div class="tags">{p.tech.map(t => <span class="tag">{t}</span>)}</div>
            </div>
          ))}
        </div>

        <hr class="divider" />

        <!-- CERTIFICAZIONI & COMPETIZIONI -->
        <div class="section">
          <div class="section-title">Certificazioni & Competizioni</div>

          <div class="competition">
            <div class="item-header">
              <span class="item-name">{cv.competitions[0].name.it}</span>
              <span class="item-date">2026</span>
            </div>
            <div class="item-sub">{cv.competitions[0].role.it}</div>
            <div style="font-size:9.5px; color:#777; font-style:italic; margin-top:2px;">{cv.competitions[0].note.it}</div>
          </div>

          {cv.certifications.map(c => (
            <div class="item">
              <div class="item-header">
                <span class="item-name" style="font-size:11px;">
                  {typeof c.name === 'object' ? c.name.it : c.name}
                  {'score' in c && c.score && (
                    <span style="font-weight:400; color:#555; font-size:10px;"> &nbsp;·&nbsp; {c.score}</span>
                  )}
                </span>
                <span class="item-date">{typeof c.date === 'object' ? c.date.it : c.date}</span>
              </div>
              <div class="item-sub">{typeof c.issuer === 'object' ? c.issuer.it : c.issuer}</div>
              {c.verifiable && (
                <div class="btc-box">
                  <div style="font-size:8px; color:#999; margin-bottom:2px;">₿ Verificabile on-chain &nbsp;·&nbsp; TxID:</div>
                  <code>{cv.certifications[0].txid}</code>
                </div>
              )}
            </div>
          ))}
        </div>

        <hr class="divider" />

        <!-- PCTO -->
        <div class="section">
          <div class="section-title">PCTO — Alternanza Scuola-Lavoro</div>
          <div class="item">
            <div class="item-header">
              <span class="item-name">IIS J.C. Maxwell &nbsp;·&nbsp; Nichelino (TO)</span>
              <span class="item-date">520 ore</span>
            </div>
            <div class="item-sub">Attività in ambito informatico e networking</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</body>
</html>
