---
import { cv } from '../data/cv.ts';
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Daniele Porcaro – CV</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #fff; color: #111; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; line-height: 1.6; }

    .page { max-width: 210mm; margin: 0 auto; padding: 14mm 16mm 12mm; }

    /* Print button — hidden when printing */
    .print-bar {
      position: fixed; top: 0; left: 0; right: 0;
      background: #111; color: #00ff88; padding: 10px 20px;
      display: flex; align-items: center; justify-content: space-between;
      font-size: 12px; z-index: 100;
    }
    .print-bar button {
      background: #00ff88; color: #000; border: none; padding: 6px 16px;
      font-family: inherit; font-size: 12px; font-weight: 700; cursor: pointer; border-radius: 4px;
    }
    @media print { .print-bar { display: none !important; } body { padding-top: 0; } }
    body { padding-top: 44px; }
    @media print { body { padding-top: 0; } }

    /* Header */
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; padding-bottom: 8px; border-bottom: 2px solid #111; }
    .header-left h1 { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; }
    .header-left h2 { font-size: 12px; color: #444; font-weight: 400; margin-top: 2px; }
    .header-right { text-align: right; font-size: 10px; color: #444; line-height: 1.8; }
    .header-right a { color: #111; text-decoration: none; }

    /* Sections */
    .section { margin-top: 9px; }
    .section-title {
      font-size: 8px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
      color: #666; border-bottom: 1px solid #ddd; padding-bottom: 3px; margin-bottom: 6px;
    }

    /* Two-column layout */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }

    /* Items */
    .item { margin-bottom: 6px; }
    .item-header { display: flex; justify-content: space-between; align-items: baseline; }
    .item-name { font-weight: 700; font-size: 11px; }
    .item-date { font-size: 9.5px; color: #666; }
    .item-sub { font-size: 9.5px; color: #444; }
    .item-desc { font-size: 9.5px; color: #333; margin-top: 2px; line-height: 1.5; }

    /* Skill bars */
    .skill-row { display: flex; align-items: center; gap: 6px; margin-bottom: 3px; }
    .skill-name { width: 90px; font-size: 9.5px; }
    .skill-bar { flex: 1; height: 3px; background: #e5e5e5; border-radius: 2px; overflow: hidden; }
    .skill-fill { height: 100%; background: #111; border-radius: 2px; }

    /* Tags */
    .tags { display: flex; flex-wrap: wrap; gap: 3px; margin-top: 3px; }
    .tag { font-size: 8.5px; padding: 1px 6px; border: 1px solid #ccc; border-radius: 3px; color: #333; }

    /* Competition */
    .competition { background: #f5f5f5; padding: 5px 8px; border-left: 3px solid #111; margin-bottom: 6px; }

    /* Highlight */
    .highlights { list-style: none; margin-top: 2px; }
    .highlights li::before { content: '· '; color: #888; }
    .highlights li { font-size: 9.5px; color: #555; }

    /* Lang table */
    .lang-row { display: flex; gap: 12px; }
    .lang-item { font-size: 9.5px; }
    .lang-code { font-weight: 700; }

    /* Bitcoin cert */
    .btc-box { background: #f9f9f9; border: 1px solid #ddd; padding: 5px 8px; border-radius: 3px; margin-top: 4px; }
    .btc-box code { font-size: 8.5px; word-break: break-all; color: #333; }

    @page { size: A4; margin: 0; }
    @media print { .page { padding: 14mm 16mm 12mm; } }
  </style>
</head>
<body>
  <div class="print-bar">
    <span>💻 daniele.porcaro — CV</span>
    <button onclick="window.print()">↓ Salva come PDF (Ctrl+P)</button>
  </div>

  <div class="page">
    <!-- HEADER -->
    <div class="header">
      <div class="header-left">
        <h1>Daniele Porcaro</h1>
        <h2>Studente di Informatica · Torino, IT</h2>
      </div>
      <div class="header-right">
        <div><a href={`mailto:${cv.email}`}>{cv.email}</a></div>
        <div><a href={cv.githubUrl}>github.com/{cv.github}</a></div>
        <div>Torino, IT · 18 anni</div>
        <div style="font-size:8.5px; color:#999; margin-top:2px;">dany80213.github.io/cv</div>
      </div>
    </div>

    <!-- ABOUT -->
    <div class="section">
      <div class="section-title">Profilo</div>
      <p style="font-size:9.5px; color:#333; line-height:1.6;">{cv.about.it}</p>
    </div>

    <div class="two-col">
      <!-- LEFT COLUMN -->
      <div>
        <!-- EDUCATION -->
        <div class="section">
          <div class="section-title">Formazione</div>
          {cv.education.map(e => (
            <div class="item">
              <div class="item-header">
                <span class="item-name">{e.school}</span>
                <span class="item-date">{e.period}</span>
              </div>
              <div class="item-sub">{e.degree.it}</div>
              <div class="item-sub" style="color:#888;">{e.location}</div>
              {e.highlights.it.length > 0 && (
                <ul class="highlights">
                  {e.highlights.it.map(h => <li>{h}</li>)}
                </ul>
              )}
            </div>
          ))}
        </div>

        <!-- LANGUAGES -->
        <div class="section">
          <div class="section-title">Lingue</div>
          <div class="lang-row">
            {cv.languages.map(l => (
              <div class="lang-item">
                <span class="lang-code">{l.code}</span> {l.lang}
                <div style="font-size:8.5px; color:#666;">{typeof l.level === 'object' ? l.level.it : l.level}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- SOFT SKILLS -->
        <div class="section">
          <div class="section-title">Soft Skills</div>
          <div class="tags">
            {cv.softSkills.it.map(s => <span class="tag">{s}</span>)}
          </div>
        </div>

        <!-- SKILLS -->
        <div class="section">
          <div class="section-title">Linguaggi</div>
          {cv.skills.languages.map(s => (
            <div class="skill-row">
              <span class="skill-name">{s.name}</span>
              <div class="skill-bar"><div class="skill-fill" style={`width:${s.level}%`}></div></div>
            </div>
          ))}
        </div>

        <div class="section">
          <div class="section-title">Framework & Tools</div>
          <div class="tags">{cv.skills.frameworks.map(f => <span class="tag">{f}</span>)}</div>
          <div class="tags" style="margin-top:3px;">{cv.skills.devops.map(d => <span class="tag">{d}</span>)}</div>
          <div class="tags" style="margin-top:3px;">{cv.skills.databases.map(d => <span class="tag">{d}</span>)}</div>
        </div>

        <div class="section">
          <div class="section-title">Hardware & Networking</div>
          <div class="tags">{cv.skills.hardware.map(h => <span class="tag">{h}</span>)}</div>
          <div class="tags" style="margin-top:3px;">{cv.skills.networking.map(n => <span class="tag">{n}</span>)}</div>
        </div>

        <div class="section">
          <div class="section-title">Blockchain & AI</div>
          <div class="tags">{cv.skills.blockchain.map(b => <span class="tag">{b}</span>)}</div>
          <div class="tags" style="margin-top:3px;">{cv.skills.ai.map(a => <span class="tag">{a}</span>)}</div>
        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div>
        <!-- PROJECTS -->
        <div class="section">
          <div class="section-title">Progetti</div>
          {cv.projects.map(p => (
            <div class="item">
              <div class="item-header">
                <span class="item-name">{typeof p.name === 'string' ? p.name : p.name.it}</span>
                {p.url && <a href={p.url} style="font-size:8.5px; color:#666;">↗ GitHub</a>}
              </div>
              <div class="item-desc">{typeof p.description === 'object' ? p.description.it : p.description}</div>
              <div class="tags">{p.tech.map(t => <span class="tag">{t}</span>)}</div>
            </div>
          ))}
        </div>

        <!-- CERTIFICATIONS -->
        <div class="section">
          <div class="section-title">Certificazioni & Competizioni</div>

          <div class="competition">
            <div class="item-header">
              <span class="item-name">{cv.competitions[0].name.it}</span>
              <span class="item-date">2026</span>
            </div>
            <div class="item-sub">{cv.competitions[0].role.it}</div>
            <div style="font-size:8.5px; color:#666; font-style:italic;">{cv.competitions[0].note.it}</div>
          </div>

          {cv.certifications.map(c => (
            <div class="item">
              <div class="item-header">
                <span class="item-name" style="font-size:10px;">{typeof c.name === 'object' ? c.name.it : c.name}</span>
                <span class="item-date">{typeof c.date === 'object' ? c.date.it : c.date}</span>
              </div>
              <div class="item-sub">{typeof c.issuer === 'object' ? c.issuer.it : c.issuer}</div>
              {c.verifiable && (
                <div class="btc-box">
                  <div style="font-size:8px; color:#888; margin-bottom:2px;">₿ Verificabile on-chain · TxID:</div>
                  <code>{cv.certifications[0].txid}</code>
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- PCTO -->
        <div class="section">
          <div class="section-title">PCTO</div>
          <div class="item">
            <div class="item-header">
              <span class="item-name">IIS J.C. Maxwell</span>
              <span class="item-date">520 ore</span>
            </div>
            <div class="item-sub">Alternanza scuola-lavoro in ambito informatico</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
