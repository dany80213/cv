---
import { cv } from '../data/cv.ts';
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Daniele Porcaro – CV</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --accent: #00c96e;
      --accent-dark: #009952;
      --dark: #0e0e16;
      --sidebar-bg: #f4f6f4;
      --text: #1a1a2e;
      --muted: #6b7280;
      --border: #e2e8e4;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: #fff;
      color: var(--text);
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 11px;
      line-height: 1.7;
    }

    /* ── print bar ── */
    .print-bar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: var(--dark); color: #fff;
      padding: 12px 28px;
      display: flex; align-items: center; justify-content: space-between;
      font-size: 12px;
    }
    .print-bar .logo { color: var(--accent); font-weight: 700; }
    .print-bar button {
      background: var(--accent); color: #000;
      border: none; padding: 8px 22px;
      font-family: inherit; font-size: 12px; font-weight: 700;
      cursor: pointer; border-radius: 5px; letter-spacing: 0.02em;
    }
    .print-bar button:hover { background: var(--accent-dark); }
    body { padding-top: 52px; }
    @media print { .print-bar { display: none !important; } body { padding-top: 0; } }

    /* ── page wrapper ── */
    .page { max-width: 210mm; margin: 0 auto; }

    /* ── hero header ── */
    .hero {
      background: var(--dark);
      color: #fff;
      padding: 28px 28px 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 20px;
    }
    .hero-name {
      font-size: 34px; font-weight: 700;
      letter-spacing: -0.03em; line-height: 1;
      color: #fff;
    }
    .hero-name span { color: var(--accent); }
    .hero-role {
      font-size: 12px; color: #94a3b8;
      font-weight: 400; margin-top: 8px;
    }
    .hero-contacts {
      text-align: right; font-size: 10px;
      color: #94a3b8; line-height: 2.1;
    }
    .hero-contacts a { color: #fff; text-decoration: none; }
    .hero-contacts .hl { color: var(--accent); }

    /* ── body layout ── */
    .body {
      display: grid;
      grid-template-columns: 195px 1fr;
    }

    /* ── sidebar ── */
    .sidebar {
      background: var(--sidebar-bg);
      padding: 22px 18px 22px 20px;
      border-right: 1px solid var(--border);
    }

    /* ── main ── */
    .main { padding: 22px 24px 22px 22px; }

    /* ── section titles ── */
    .section { margin-bottom: 20px; }
    .section:last-child { margin-bottom: 0; }

    .section-title {
      font-size: 7.5px; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--accent-dark);
      display: flex; align-items: center; gap: 6px;
      margin-bottom: 11px;
    }
    .section-title::after {
      content: ''; flex: 1; height: 1px;
      background: var(--border);
    }

    /* ── items ── */
    .item { margin-bottom: 13px; }
    .item:last-child { margin-bottom: 0; }

    .item-row { display: flex; justify-content: space-between; align-items: baseline; gap: 6px; }
    .item-name { font-weight: 700; font-size: 11px; color: var(--text); }
    .item-date { font-size: 9.5px; color: var(--accent-dark); font-weight: 600; white-space: nowrap; }
    .item-sub { font-size: 10px; color: var(--muted); margin-top: 1px; }
    .item-desc { font-size: 10px; color: #374151; margin-top: 4px; line-height: 1.65; }

    /* ── highlights ── */
    .highlights { list-style: none; margin-top: 5px; }
    .highlights li {
      font-size: 9.5px; color: var(--muted);
      padding-left: 10px; position: relative; margin-bottom: 1px;
    }
    .highlights li::before { content: '▸'; position: absolute; left: 0; color: var(--accent); font-size: 8px; top: 1px; }

    /* ── skill bars ── */
    .skill-row { display: flex; align-items: center; gap: 7px; margin-bottom: 7px; }
    .skill-name { width: 80px; font-size: 9.5px; color: var(--text); }
    .skill-bar { flex: 1; height: 4px; background: #dde8dd; border-radius: 2px; overflow: hidden; }
    .skill-fill { height: 100%; background: var(--accent); border-radius: 2px; }
    .skill-pct { font-size: 8.5px; color: var(--muted); width: 24px; text-align: right; }

    /* ── tags ── */
    .tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 5px; }
    .tag {
      font-size: 8.5px; padding: 2px 7px;
      border: 1px solid #c9d8c9; border-radius: 3px;
      color: #374151; background: #fff;
    }

    /* ── competition box ── */
    .competition {
      background: #fff;
      border: 1px solid var(--accent);
      border-left: 4px solid var(--accent);
      padding: 9px 12px;
      border-radius: 0 5px 5px 0;
      margin-bottom: 12px;
    }
    .competition .badge {
      display: inline-block; background: var(--accent);
      color: #000; font-size: 7.5px; font-weight: 700;
      padding: 1px 7px; border-radius: 10px;
      letter-spacing: 0.05em; margin-bottom: 5px;
    }

    /* ── btc box ── */
    .btc-box {
      background: #f0faf4; border: 1px solid #b6ddc8;
      padding: 7px 10px; border-radius: 4px; margin-top: 6px;
    }
    .btc-box .btc-label { font-size: 7.5px; color: var(--accent-dark); margin-bottom: 2px; font-weight: 700; }
    .btc-box code { font-size: 8px; word-break: break-all; color: #374151; }

    /* ── score pill ── */
    .score-pill {
      display: inline-block;
      background: var(--accent); color: #000;
      font-size: 8.5px; font-weight: 700;
      padding: 1px 8px; border-radius: 10px;
      margin-left: 6px; vertical-align: middle;
    }

    /* ── lang items ── */
    .lang-item { margin-bottom: 9px; }
    .lang-code { font-size: 15px; font-weight: 700; color: var(--accent-dark); }
    .lang-name { font-size: 10px; color: var(--text); font-weight: 600; }
    .lang-level { font-size: 9px; color: var(--muted); }

    /* ── divider ── */
    hr { border: none; border-top: 1px solid var(--border); margin: 16px 0; }

    /* ── PCTO strip ── */
    .pcto-strip {
      background: var(--dark); color: #fff;
      padding: 10px 14px; border-radius: 5px;
      display: flex; justify-content: space-between; align-items: center;
    }
    .pcto-strip .hours { color: var(--accent); font-weight: 700; font-size: 16px; }

    @page { size: A4; margin: 0; }
    @media print { .page { max-width: 100%; } }
  </style>
</head>
<body>

  <div class="print-bar">
    <span class="logo">~/daniele.porcaro</span>
    <button onclick="window.print()">↓ Salva come PDF &nbsp;(Ctrl+P)</button>
  </div>

  <div class="page">

    <!-- HERO HEADER -->
    <div class="hero">
      <div>
        <div class="hero-name">Daniele<br/><span>Porcaro</span></div>
        <div class="hero-role">Studente di Informatica &nbsp;·&nbsp; Torino, IT</div>
      </div>
      <div class="hero-contacts">
        <div><a href={`mailto:${cv.email}`}>{cv.email}</a></div>
        <div><a href={cv.githubUrl}>github.com/<span class="hl">{cv.github}</span></a></div>
        <div>18 anni</div>
        <div style="font-size:9px; color:#4a5568; margin-top:3px;">dany80213.github.io/cv</div>
      </div>
    </div>

    <div class="body">

      <!-- ══ SIDEBAR ══ -->
      <div class="sidebar">

        <!-- Formazione -->
        <div class="section">
          <div class="section-title">Formazione</div>
          {cv.education.map(e => (
            <div class="item">
              <div class="item-name">{e.school}</div>
              <div class="item-sub">{e.location}</div>
              <div style="font-size:9.5px; color:var(--accent-dark); font-weight:600; margin-top:2px;">{e.period}</div>
              <div class="item-sub" style="margin-top:2px;">{e.degree.it}</div>
              {e.highlights.it.length > 0 && (
                <ul class="highlights">
                  {e.highlights.it.map(h => <li>{h}</li>)}
                </ul>
              )}
            </div>
          ))}
        </div>

        <!-- Lingue -->
        <div class="section">
          <div class="section-title">Lingue</div>
          {cv.languages.map(l => (
            <div class="lang-item">
              <span class="lang-code">{l.code}</span>
              <span class="lang-name"> {l.lang}</span>
              <div class="lang-level">{typeof l.level === 'object' ? l.level.it : l.level}</div>
            </div>
          ))}
        </div>

        <!-- Soft Skills -->
        <div class="section">
          <div class="section-title">Soft Skills</div>
          <div class="tags">
            {cv.softSkills.it.map(s => <span class="tag">{s}</span>)}
          </div>
        </div>

        <!-- Linguaggi -->
        <div class="section">
          <div class="section-title">Linguaggi</div>
          {cv.skills.languages.map(s => (
            <div class="skill-row">
              <span class="skill-name">{s.name}</span>
              <div class="skill-bar"><div class="skill-fill" style={`width:${s.level}%`}></div></div>
              <span class="skill-pct">{s.level}%</span>
            </div>
          ))}
        </div>

        <!-- Framework & Tools -->
        <div class="section">
          <div class="section-title">Framework</div>
          <div class="tags">{cv.skills.frameworks.map(f => <span class="tag">{f}</span>)}</div>
          <div class="tags" style="margin-top:4px;">{cv.skills.devops.map(d => <span class="tag">{d}</span>)}</div>
          <div class="tags" style="margin-top:4px;">{cv.skills.databases.map(d => <span class="tag">{d}</span>)}</div>
        </div>

        <!-- Hardware & Net -->
        <div class="section">
          <div class="section-title">Hardware & Net</div>
          <div class="tags">{cv.skills.hardware.map(h => <span class="tag">{h}</span>)}</div>
          <div class="tags" style="margin-top:4px;">{cv.skills.networking.map(n => <span class="tag">{n}</span>)}</div>
        </div>

        <!-- Blockchain & AI -->
        <div class="section">
          <div class="section-title">Blockchain & AI</div>
          <div class="tags">{cv.skills.blockchain.map(b => <span class="tag">{b}</span>)}</div>
          <div class="tags" style="margin-top:4px;">{cv.skills.ai.map(a => <span class="tag">{a}</span>)}</div>
        </div>

      </div>

      <!-- ══ MAIN ══ -->
      <div class="main">

        <!-- Profilo -->
        <div class="section">
          <div class="section-title">Profilo</div>
          <p style="font-size:10.5px; color:#374151; line-height:1.8;">{cv.about.it}</p>
        </div>

        <!-- Progetti -->
        <div class="section">
          <div class="section-title">Progetti</div>
          {cv.projects.map(p => (
            <div class="item">
              <div class="item-row">
                <span class="item-name">{typeof p.name === 'string' ? p.name : p.name.it}</span>
                {p.url && <a href={p.url} style="font-size:9px; color:var(--accent-dark); text-decoration:none; font-weight:600;">↗ GitHub</a>}
              </div>
              <div class="item-desc">{typeof p.description === 'object' ? p.description.it : p.description}</div>
              <div class="tags">{p.tech.map(t => <span class="tag">{t}</span>)}</div>
            </div>
          ))}
        </div>

        <hr />

        <!-- Certificazioni & Competizioni -->
        <div class="section">
          <div class="section-title">Certificazioni & Competizioni</div>

          <div class="competition">
            <div class="badge">🏆 COMPETIZIONE NAZIONALE</div>
            <div class="item-row">
              <span class="item-name">{cv.competitions[0].name.it}</span>
              <span class="item-date">2026</span>
            </div>
            <div class="item-sub">{cv.competitions[0].role.it}</div>
            <div style="font-size:9px; color:var(--muted); font-style:italic; margin-top:2px;">{cv.competitions[0].note.it}</div>
          </div>

          {cv.certifications.map(c => (
            <div class="item">
              <div class="item-row">
                <span class="item-name">
                  {typeof c.name === 'object' ? c.name.it : c.name}
                  {'score' in c && c.score && <span class="score-pill">{c.score}</span>}
                </span>
                <span class="item-date">{typeof c.date === 'object' ? c.date.it : c.date}</span>
              </div>
              <div class="item-sub">{typeof c.issuer === 'object' ? c.issuer.it : c.issuer}</div>
              {c.verifiable && (
                <div class="btc-box">
                  <div class="btc-label">₿ Verificabile on-chain · TxID</div>
                  <code>{cv.certifications[0].txid}</code>
                </div>
              )}
            </div>
          ))}
        </div>

        <hr />

        <!-- PCTO -->
        <div class="section">
          <div class="section-title">PCTO — Alternanza Scuola-Lavoro</div>
          <div class="pcto-strip">
            <div>
              <div style="font-size:11px; font-weight:700;">IIS J.C. Maxwell · Nichelino (TO)</div>
              <div style="font-size:9.5px; color:#94a3b8; margin-top:3px;">Attività in ambito informatico e networking</div>
            </div>
            <div class="hours">520h</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</body>
</html>
